#ifndef SRC_AP_AP_C_
#define SRC_AP_AP_C_


#include "ap.h"


void apInit(void)
{
   uartOpen(_DEF_UART1, 115200); //
}

void apMain(void)
{

	while(1)
	{

		    uartPrintf(_DEF_UART1, "a");

			if (uartAvailable(_DEF_UART1) == 0)
			{
				uint8_t rx_data = uartRead(_DEF_UART1);
				uartPrintf(_DEF_UART1, "rx_data : %c\n\r", rx_data);

			}





	}
}




#endif /* SRC_AP_AP_C_ */
